# ── Supabase (central-apps project, ref wdzmuniyqqyngzckeoph) ──────────────
# Server-side use only. The service-role / secret key bypasses RLS — never expose it.
SUPABASE_URL=https://wdzmuniyqqyngzckeoph.supabase.co
# Legacy JWT keys (the pipeline uses SUPABASE_SERVICE_ROLE_KEY):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
# New-format API keys (optional; stored for tooling that prefers them):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── Discord ────────────────────────────────────────────────────────────────
# Webhook the pipeline posts a run summary to when it finishes.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# ── Optional ───────────────────────────────────────────────────────────────
# Brand slug used in the brand knowledge graph (showcase lookup).
BRAND_SLUG=opencraft
# Path to the prebuilt google-maps-scraper binary (defaults to ../google-maps-scraper/google-maps-scraper).
# SCRAPER_BIN=/home/muhammad/repo-wsl/cold-email-automation/scrappers/google-maps-scraper/google-maps-scraper
# Playwright platform override (required on Ubuntu 26.04 host).
PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu24.04-x64
